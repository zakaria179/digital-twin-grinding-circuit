# =========================================================================
# Digital Twin System Architecture - Environment Variables Template
# =========================================================================

# Custom Docker Bridge Network
NETWORK_NAME=digital_twin_network

# Inductive Automation Ignition Configuration
IGNITION_HTTP_PORT=8088
IGNITION_HTTPS_PORT=8043
IGNITION_ADMIN_USER=admin
IGNITION_ADMIN_PASSWORD=change_this_password
IGNITION_EDITION=standard

# HighByte Intelligence Hub Configuration
HIGHBYTE_PORT=45245
HIGHBYTE_ADMIN_PASSWORD=change_this_password

# Eclipse BaSyx Asset Administration Shell (AAS) Configuration
BASYX_AAS_SERVER_PORT=4001
BASYX_UI_PORT=3000

# MinIO Object Storage (Raw Data Lake Landing Zone) Configuration
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_password
MINIO_RAW_BUCKET=raw-data-lake
